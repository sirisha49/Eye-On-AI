# ============================================================
# EyeOnAI — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Azure OpenAI — shared endpoint for both models
# Find these in: Azure Portal → Azure OpenAI resource → Keys and Endpoint
# ------------------------------------------------------------
AZURE_AI_PROJECT_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_AI_API_KEY=<your-azure-openai-api-key>

# ------------------------------------------------------------
# Answerer deployment — Layer 1 answer generation
# The primary model that generates answers (recommended: gpt-4o)
# Deploy this model in Azure OpenAI Studio and paste the deployment name below
# ------------------------------------------------------------
AZURE_ANSWERER_DEPLOYMENT=gpt-4o

# ------------------------------------------------------------
# Evaluator deployment — Layer 2 independent judge
# A separate, smaller model used as the independent evaluator (recommended: gpt-4o-mini)
# Must be a DIFFERENT deployment from the answerer to avoid self-grading
# ------------------------------------------------------------
AZURE_EVALUATOR_DEPLOYMENT=gpt-4o-mini

# ------------------------------------------------------------
# (Optional) Azure AI Foundry — Foundry IQ retrieval
# Required only when swapping mock_iq.py for real Foundry IQ retrieval
# Find in: Azure AI Foundry portal → your project → Settings
# ------------------------------------------------------------
# AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.api.azureml.ms
# AZURE_FOUNDRY_PROJECT_NAME=<your-project-name>

# ------------------------------------------------------------
# (Optional) Microsoft Fabric — Fabric IQ trend intelligence
# Required only when swapping mock_iq.py for real Fabric IQ queries
# ------------------------------------------------------------
# FABRIC_WORKSPACE_ID=<your-fabric-workspace-id>
# FABRIC_DATASET_ID=<your-fabric-dataset-id>
